# Copy to .env and fill in. .env is gitignored.

# Sepolia JSON-RPC endpoint (Alchemy, Infura, public RPC, etc.)
SEPOLIA_RPC_URL=

# Private key of the deploying account. The deployer becomes the
# immutable `venue` -- choose a key whose recovery you trust.
DEPLOYER_PRIVATE_KEY=

# Etherscan API key for source verification on deploy.
ETHERSCAN_API_KEY=

# Price per pass, in wei. Immutable post-deploy.
# Example: 10000000000000000 = 0.01 ETH
TICKET_PRICE_WEI=

# Maximum outstanding supply (returns free room for re-mint).
# Note: TICKET_PRICE_WEI * MAX_SUPPLY is the cap on SETH the contract
# will ever escrow.
MAX_SUPPLY=
